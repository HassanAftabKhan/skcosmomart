generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  salePrice   Float?
  stock       Int      @default(0)
  category    String
  images      String   // JSON string of image URLs
  benefits    String?
  ingredients String?
  howToUse    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String
  customerCity  String
  address       String
  totalAmount   Float
  status        String   @default("PENDING") // PENDING, CONFIRMED, DISPATCHED, DELIVERED
  paymentMethod String   @default("COD")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orderItems    OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN") // ADMIN or CUSTOMER
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
